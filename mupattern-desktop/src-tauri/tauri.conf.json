{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuPattern",
  "version": "0.3.3",
  "identifier": "org.mupattern.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MuPattern",
        "width": 1440,
        "height": 900
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns"
    ],
    "targets": "all"
  }
}
